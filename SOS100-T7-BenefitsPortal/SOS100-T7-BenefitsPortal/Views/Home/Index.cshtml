@{
    ViewData["Title"] = "Startsida";
}

<div class="py-4">
    <div class="p-5 mb-5 text-white rounded-3" style="background-color: #2E7D32;">
        <h1 class="display-5 fw-bold">Välkommen till Medarbetarförmånsportalen</h1>
        <p class="col-md-8 fs-5 mt-3">Här hittar du och hanterar alla dina förmåner, ansökningar och meddelanden på ett och samma ställe.</p>
        <a class="btn btn-light btn-lg" asp-controller="Benefits" asp-action="Index">Se förmåner</a>
    </div>

    <h2 class="mb-4">Tjänster</h2>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <div class="col">
            <div class="card h-100 text-white" style="background-color: #2E7D32;">
                <div class="card-body">
                    <h5 class="card-title">Förmåner</h5>
                    <p class="card-text" style="color: rgba(255,255,255,0.85);">Bläddra bland tillgängliga förmåner och ta del av det vi erbjuder.</p>
                </div>
                <div class="card-footer" style="background-color: rgba(0,0,0,0.12); border-color: rgba(255,255,255,0.2);">
                    <a asp-controller="Benefits" asp-action="Index" class="btn btn-light w-100 fw-semibold" style="color: #2E7D32;">Öppna</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 text-white" style="background-color: #2E7D32;">
                <div class="card-body">
                    <h5 class="card-title">Ansökningar</h5>
                    <p class="card-text" style="color: rgba(255,255,255,0.85);">Hantera dina ansökningar om förmåner och följ deras status.</p>
                </div>
                <div class="card-footer" style="background-color: rgba(0,0,0,0.12); border-color: rgba(255,255,255,0.2);">
                    <a asp-controller="Applications" asp-action="Index" class="btn btn-outline-light w-100">Öppna</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 text-white" style="background-color: #2E7D32;">
                <div class="card-body">
                    <h5 class="card-title">Meddelanden</h5>
                    <p class="card-text" style="color: rgba(255,255,255,0.85);">Läs notiser och kommunikation kring dina förmåner.</p>
                </div>
                <div class="card-footer" style="background-color: rgba(0,0,0,0.12); border-color: rgba(255,255,255,0.2);">
                    <a asp-controller="Notifications" asp-action="Index" class="btn btn-outline-light w-100">Öppna</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 text-white" style="background-color: #2E7D32;">
                <div class="card-body">
                    <h5 class="card-title">Min profil</h5>
                    <p class="card-text" style="color: rgba(255,255,255,0.85);">Hantera dina uppgifter och inställningar.</p>
                </div>
                <div class="card-footer" style="background-color: rgba(0,0,0,0.12); border-color: rgba(255,255,255,0.2);">
                    <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-light w-100">Öppna</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 text-white" style="background-color: #2E7D32;">
                <div class="card-body">
                    <h5 class="card-title">Rapporter</h5>
                    <p class="card-text" style="color: rgba(255,255,255,0.85);">Analysera nyttjande och kostnader för förmånsprogrammet.</p>
                </div>
                <div class="card-footer" style="background-color: rgba(0,0,0,0.12); border-color: rgba(255,255,255,0.2);">
                    <a asp-controller="Reports" asp-action="Index" class="btn btn-outline-light w-100">Öppna</a>
                </div>
            </div>
        </div>
    </div>
</div>