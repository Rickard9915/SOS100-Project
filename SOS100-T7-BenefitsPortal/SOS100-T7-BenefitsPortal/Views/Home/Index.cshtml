@{
    ViewData["Title"] = "Startsida";
}

<div class="py-4">
    <div class="p-5 mb-5 bg-dark text-white rounded-3">
        <h1 class="display-5 fw-bold">Välkommen till Medarbetarförmånsportalen</h1>
        <p class="col-md-8 fs-5 mt-3">Här hittar du och hanterar alla dina förmåner, ansökningar och meddelanden på ett och samma ställe.</p>
        <a class="btn btn-light btn-lg" asp-controller="Benefits" asp-action="Index">Se förmåner</a>
    </div>

    <h2 class="mb-4">Tjänster</h2>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Förmåner</h5>
                    <p class="card-text text-muted">Bläddra bland tillgängliga förmåner och ta del av det vi erbjuder.</p>
                </div>
                <div class="card-footer bg-transparent">
                    <a asp-controller="Benefits" asp-action="Index" class="btn btn-primary w-100">Öppna</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Ansökningar</h5>
                    <p class="card-text text-muted">Hantera dina ansökningar om förmåner och följ deras status.</p>
                </div>
                <div class="card-footer bg-transparent">
                    <button class="btn btn-outline-secondary w-100" disabled>Kommer snart</button>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Meddelanden</h5>
                    <p class="card-text text-muted">Läs notiser och kommunikation kring dina förmåner.</p>
                </div>
                <div class="card-footer bg-transparent">
                    <button class="btn btn-outline-secondary w-100" disabled>Kommer snart</button>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Min profil</h5>
                    <p class="card-text text-muted">Hantera dina uppgifter och inställningar.</p>
                </div>
                <div class="card-footer bg-transparent">
                    <button class="btn btn-outline-secondary w-100" disabled>Kommer snart</button>
                </div>
            </div>
        </div>
    </div>
</div>