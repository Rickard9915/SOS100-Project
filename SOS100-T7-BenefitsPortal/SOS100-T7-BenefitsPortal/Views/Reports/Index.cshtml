@{
    ViewData["Title"] = "Rapporter";
}

<div class="text-center py-5">
    <div class="mb-4">
        <span style="font-size: 4rem; line-height: 1;">&#128202;</span>
    </div>
    <h1 class="mb-3">Rapporter</h1>
    <p class="text-muted fs-5 mb-4 mx-auto" style="max-width: 480px;">
        Här kommer du kunna analysera nyttjande och kostnader för förmånsprogrammet.
        Sidan kopplas mot <strong>ReportService</strong> och är under uppbyggnad.
    </p>
    <span class="badge bg-warning text-dark fs-6 px-3 py-2">Kommer snart</span>
    <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
            &larr; Tillbaka till startsidan
        </a>
    </div>
</div>
