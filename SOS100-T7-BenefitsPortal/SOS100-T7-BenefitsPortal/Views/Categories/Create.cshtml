@model SOS100_T7_BenefitsPortal.Models.CategoryFormModel

@{
    ViewData["Title"] = "Ny kategori";
}

<div class="mb-3">
    <a asp-action="Index" class="text-decoration-none">&larr; Tillbaka till kategorier</a>
</div>

<h1 class="mb-4">Ny kategori</h1>

<div style="max-width: 400px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-4">
            <label asp-for="Name" class="form-label">Namn</label>
            <input asp-for="Name" class="form-control" placeholder="T.ex. Hälsa" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Skapa kategori</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Avbryt</a>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
