@model List<SOS100_T7_BenefitsPortal.Models.CategoryViewModel>

@{
    ViewData["Title"] = "Kategorier";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Kategorier</h1>
    <a asp-action="Create" class="btn btn-sm btn-primary">+ Ny kategori</a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Inga kategorier hittades.</div>
}
else
{
    <div class="card shadow-sm" style="max-width: 520px;">
        <ul class="list-group list-group-flush">
            @foreach (var category in Model)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span>@category.Name</span>
                    <div class="d-flex gap-1">
                        <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-secondary">Redigera</a>
                        <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-sm btn-outline-danger">Ta bort</a>
                    </div>
                </li>
            }
        </ul>
    </div>
}

<div class="mt-3">
    <a asp-controller="Benefits" asp-action="Index" class="text-decoration-none">&larr; Tillbaka till förmåner</a>
</div>
