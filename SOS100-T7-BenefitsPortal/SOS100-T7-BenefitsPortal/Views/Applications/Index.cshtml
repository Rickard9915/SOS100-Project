@{
    ViewData["Title"] = "Ansökningar";
}

<div class="text-center py-5">
    <div class="mb-4">
        <span style="font-size: 4rem; line-height: 1;">&#128203;</span>
    </div>
    <h1 class="mb-3">Ansökningar</h1>
    <p class="text-muted fs-5 mb-4 mx-auto" style="max-width: 480px;">
        Här kommer du kunna skicka in och följa upp ansökningar om förmåner.
        Sidan kopplas mot <strong>ApplicationService</strong> och är under uppbyggnad.
    </p>
    <span class="badge bg-warning text-dark fs-6 px-3 py-2">Kommer snart</span>
    <div class="mt-4">
        <a asp-controller="Benefits" asp-action="Index" class="btn btn-outline-secondary">
            &larr; Tillbaka till förmåner
        </a>
    </div>
</div>
