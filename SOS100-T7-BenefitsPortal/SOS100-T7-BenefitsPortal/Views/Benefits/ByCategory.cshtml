@model List<SOS100_T7_BenefitsPortal.Models.BenefitViewModel>

@{
    var category = ViewBag.Category as SOS100_T7_BenefitsPortal.Models.CategoryViewModel;
    ViewData["Title"] = category?.Name ?? "Förmåner per kategori";
}

<div class="mb-3">
    <a asp-action="Index" class="text-decoration-none">&larr; Alla förmåner</a>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">@category?.Name</h1>
    <span class="text-muted">@Model.Count förmåner</span>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Inga förmåner i denna kategori.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var benefit in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@benefit.Title</h5>
                        <p class="card-text text-muted">@benefit.Description</p>
                    </div>
                    <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
                        <span class="fs-5 fw-semibold text-success">@benefit.Value.ToString("N0") kr</span>
                        <a asp-action="Details" asp-route-id="@benefit.Id" class="btn btn-sm btn-outline-primary">Detaljer</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
