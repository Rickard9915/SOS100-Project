@model SOS100_T7_BenefitsPortal.Models.BenefitViewModel

@{
    ViewData["Title"] = "Ta bort förmån";
}

<div class="mb-3">
    <a asp-action="Details" asp-route-id="@Model.Id" class="text-decoration-none">&larr; Tillbaka till detaljer</a>
</div>

<h1 class="mb-4 text-danger">Ta bort förmån</h1>

<div class="card border-danger shadow-sm" style="max-width: 520px;">
    <div class="card-body">
        <p class="mb-3">Är du säker på att du vill ta bort följande förmån?</p>
        <dl class="row mb-0">
            <dt class="col-sm-4">Titel</dt>
            <dd class="col-sm-8">@Model.Title</dd>

            <dt class="col-sm-4">Beskrivning</dt>
            <dd class="col-sm-8">@Model.Description</dd>

            <dt class="col-sm-4">Värde</dt>
            <dd class="col-sm-8">@Model.Value.ToString("N0") kr</dd>

            <dt class="col-sm-4">Kategori</dt>
            <dd class="col-sm-8">@(Model.CategoryName is { Length: > 0 } name ? name : "-")</dd>
        </dl>
    </div>
    <div class="card-footer bg-transparent d-flex gap-2">
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">Ja, ta bort</button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary">Avbryt</a>
    </div>
</div>
