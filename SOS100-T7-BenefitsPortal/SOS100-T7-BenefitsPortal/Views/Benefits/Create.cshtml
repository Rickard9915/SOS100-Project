@model SOS100_T7_BenefitsPortal.Models.BenefitFormModel

@{
    ViewData["Title"] = "Ny förmån";
}

<div class="mb-3">
    <a asp-action="Index" class="text-decoration-none">&larr; Tillbaka till förmåner</a>
</div>

<h1 class="mb-4">Ny förmån</h1>

<div style="max-width: 520px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="Title" class="form-label">Titel</label>
            <input asp-for="Title" class="form-control" placeholder="T.ex. Gymkort" />
            <span asp-validation-for="Title" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label">Beskrivning</label>
            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Beskriv förmånen..."></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Value" class="form-label">Värde (kr)</label>
            <input asp-for="Value" type="number" step="1" min="0" class="form-control" />
            <span asp-validation-for="Value" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="CategoryId" class="form-label">Kategori</label>
            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                <option value="">-- Välj kategori --</option>
            </select>
            <span asp-validation-for="CategoryId" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Skapa förmån</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Avbryt</a>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
