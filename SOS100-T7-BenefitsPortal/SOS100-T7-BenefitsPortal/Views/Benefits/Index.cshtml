@model List<SOS100_T7_BenefitsPortal.Models.BenefitViewModel>

@{
    ViewData["Title"] = "Förmåner";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Förmåner</h1>
    <div class="d-flex gap-2 align-items-center">
        <span class="text-muted me-2">@Model.Count förmåner tillgängliga</span>
        <a asp-action="Create" class="btn btn-sm btn-primary">+ Ny förmån</a>
        <a asp-controller="Categories" asp-action="Index" class="btn btn-sm btn-outline-secondary">Hantera kategorier</a>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Inga förmåner hittades.</div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-7">
            <input id="benefit-search" type="text" class="form-control" placeholder="Sök på titel..." />
        </div>
        <div class="col-md-5">
            <select id="category-filter" class="form-select">
                <option value="">Alla kategorier</option>
            </select>
        </div>
    </div>

    <div id="no-results" class="alert alert-info d-none">Inga förmåner matchar sökningen.</div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4" id="benefits-grid">
        @foreach (var benefit in Model)
        {
            <div class="col benefit-card"
                 data-title="@benefit.Title.ToLower()"
                 data-category-id="@benefit.CategoryId"
                 data-category-name="@benefit.CategoryName">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@benefit.Title</h5>
                            @if (benefit.Category is not null)
                            {
                                <a asp-action="ByCategory" asp-route-id="@benefit.Category.Id"
                                   class="badge bg-secondary text-decoration-none ms-2">@benefit.Category.Name</a>
                            }
                        </div>
                        <p class="card-text text-muted">@benefit.Description</p>
                    </div>
                    <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
                        <span class="fs-5 fw-semibold text-success">@benefit.Value.ToString("N0") kr</span>
                        <div class="d-flex gap-1">
                            <a asp-action="Details" asp-route-id="@benefit.Id" class="btn btn-sm btn-outline-primary">Detaljer</a>
                            <a asp-action="Edit" asp-route-id="@benefit.Id" class="btn btn-sm btn-outline-secondary">Redigera</a>
                            <a asp-action="Delete" asp-route-id="@benefit.Id" class="btn btn-sm btn-outline-danger">Ta bort</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
<script>
    (function () {
        const searchInput = document.getElementById('benefit-search');
        const categoryFilter = document.getElementById('category-filter');
        const cards = document.querySelectorAll('.benefit-card');
        const noResults = document.getElementById('no-results');

        // Populate category dropdown from card data
        const seen = new Set();
        cards.forEach(card => {
            const id = card.dataset.categoryId;
            const name = card.dataset.categoryName;
            if (id && name && !seen.has(id)) {
                seen.add(id);
                const opt = document.createElement('option');
                opt.value = id;
                opt.textContent = name;
                categoryFilter.appendChild(opt);
            }
        });

        function filter() {
            const search = searchInput.value.toLowerCase();
            const catId = categoryFilter.value;
            let visible = 0;
            cards.forEach(card => {
                const matchTitle = card.dataset.title.includes(search);
                const matchCat = !catId || card.dataset.categoryId === catId;
                const show = matchTitle && matchCat;
                card.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            noResults.classList.toggle('d-none', visible > 0);
        }

        searchInput.addEventListener('input', filter);
        categoryFilter.addEventListener('change', filter);
    })();
</script>
}
