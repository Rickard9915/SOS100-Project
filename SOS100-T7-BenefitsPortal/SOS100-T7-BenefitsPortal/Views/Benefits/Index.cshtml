@model List<SOS100_T7_BenefitsPortal.Models.BenefitViewModel>

@{
    ViewData["Title"] = "Förmåner";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Förmåner</h1>
    <div class="d-flex gap-2 align-items-center">
        <span class="text-muted me-2">@Model.Count förmåner tillgängliga</span>
        <a asp-action="Create" class="btn btn-sm btn-primary">+ Ny förmån</a>
        <a asp-controller="Categories" asp-action="Index" class="btn btn-sm btn-outline-secondary">Hantera kategorier</a>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Inga förmåner hittades.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var benefit in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@benefit.Title</h5>
                            @if (benefit.Category is not null)
                            {
                                <a asp-action="ByCategory" asp-route-id="@benefit.Category.Id"
                                   class="badge bg-secondary text-decoration-none ms-2">@benefit.Category.Name</a>
                            }
                        </div>
                        <p class="card-text text-muted">@benefit.Description</p>
                    </div>
                    <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
                        <span class="fs-5 fw-semibold text-success">@benefit.Value.ToString("N0") kr</span>
                        <div class="d-flex gap-1">
                            <a asp-action="Details" asp-route-id="@benefit.Id" class="btn btn-sm btn-outline-primary">Detaljer</a>
                            <a asp-action="Edit" asp-route-id="@benefit.Id" class="btn btn-sm btn-outline-secondary">Redigera</a>
                            <a asp-action="Delete" asp-route-id="@benefit.Id" class="btn btn-sm btn-outline-danger">Ta bort</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
