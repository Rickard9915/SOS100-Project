<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Medarbetarförmånsportal</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/SOS100_T7_BenefitsPortal.styles.css" asp-append-version="true"/>
    <style>
        .nav-btn {
            border: 1px solid rgba(255, 255, 255, 0.55) !important;
            border-radius: 5px;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.25);
            margin: 2px 3px;
            padding: 4px 12px !important;
            transition: background-color 0.15s ease, border-color 0.15s ease;
        }
        .nav-btn:hover {
            background-color: rgba(255, 255, 255, 0.18) !important;
            border-color: rgba(255, 255, 255, 0.9) !important;
        }
    </style>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-bottom box-shadow mb-3"
         style="background-color: #2E7D32;">
        <div class="container-fluid">
            <a class="navbar-brand fw-semibold text-white" asp-area="" asp-controller="Home" asp-action="Index">Medarbetarförmånsportal</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link text-white nav-btn" asp-controller="Benefits" asp-action="Index">Förmåner</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white nav-btn" asp-controller="Applications" asp-action="Index">Ansökningar</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white nav-btn" asp-controller="Notifications" asp-action="Index">Meddelanden</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white nav-btn" asp-controller="Profile" asp-action="Index">Min profil</a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link text-white nav-btn" asp-controller="Account" asp-action="Login">Logga in</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white nav-btn" asp-controller="Account" asp-action="Logout">Logga ut</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - Medarbetarförmånsportal
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>